# Copy this file to .env and replace each required value before starting
# Docker Compose. Keep .env private; it is ignored by Git.

# Required Twitch application credentials:
# https://dev.twitch.tv/console/apps
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# URL used in generated playlists and Jellyfin integration callbacks.
SERVER_URL=http://localhost:8080

# Required shared secret for Jellyfin webhook requests.
JELLYFIN_WEBHOOK_SECRET=

# Optional runtime settings.
LOG_LEVEL=INFO
VOD_RETENTION_DAYS=30
